# ════════════════════════════════════════════════════════════════════════════════
# AI DevOps Agent - Environment Configuration
# ════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and adjust values as needed.
# ════════════════════════════════════════════════════════════════════════════════

# ── Required: LLM API Keys ─────────────────────────────────────────────────────
# Choose one or both (OpenRouter takes priority if both are set)
# Uncomment and fill in your actual API keys:
# OPENROUTER_API_KEY="your-openrouter-api-key-here"
# OPENAI_API_KEY="your-openai-api-key-here"

# ── Optional: LLM Model Selection ─────────────────────────────────────────────
# Default model when using OpenRouter (default: openai/gpt-5-nano)
# OPENROUTER_MODEL="openai/gpt-5-nano"

# Default model when using OpenAI (default: gpt-5-nano)
# OPENAI_MODEL="gpt-5-nano"

# ── Local LLM Selection (Ollama) ─────────────────────────────────────────────
# Explicitly set the provider: "openai", "openrouter", "ollama"
# LLM_PROVIDER=ollama

# Ollama settings (default: http://localhost:11434, model: llama3)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3"
# OLLAMA_EMBEDDING_MODEL="mxbai-embed-large"


# LLM temperature: 0 = deterministic, higher = more creative (default: 0)
# LLM_TEMPERATURE=0

# ── Optional: Tavily Search API ───────────────────────────────────────────────
# Required for web search functionality during planning
# TAVILY_API_KEY="tvly-your-api-key-here"

# ── Optional: Plan Cache Backend ──────────────────────────────────────────────
# SQLite database path (default: .plan_cache.db)
# PLAN_CACHE_DB_PATH=.plan_cache.db

# Choose between "sqlite" (default) or "singlestore"
# PLAN_CACHE_BACKEND=singlestore

# SingleStore connection settings (only used if PLAN_CACHE_BACKEND=singlestore)
# SINGLESTORE_HOST=localhost
# SINGLESTORE_PORT=3333
# SINGLESTORE_USER=root
# SINGLESTORE_PASSWORD=
# SINGLESTORE_DATABASE=inst_agent

# ── Cache Configuration ───────────────────────────────────────────────────────
# Hybrid search alpha: 0 = pure FTS, 1 = pure vector (default: 0.6)
# PLAN_CACHE_ALPHA=0.6

# Maximum candidates from hybrid search (default: 3)
# PLAN_CACHE_MAX_CANDIDATES=3

# Minimum hybrid score threshold (default: 0.0)
# PLAN_CACHE_SCORE_THRESHOLD=0.0

# Cache TTL in days (default: 30)
# PLAN_CACHE_TTL_DAYS=30

# ── Agent Configuration ───────────────────────────────────────────────────────
# Maximum consecutive failures before stopping (default: 10)
# MAX_CONSECUTIVE_FAILURES=10

# Maximum Tavily searches per command execution (default: 3)
# MAX_SEARCHES_PER_COMMAND=3

# ── Auditor Configuration ───────────────────────────────────────────────────────
# Set to 1 to enable the auditor agent (default: 0)
# ENABLE_AUDITOR=0

# ── Timeout Configuration (seconds) ───────────────────────────────────────────
# Timeout for plan generation (default: 120)
# PLAN_TIMEOUT=120

# Timeout for plan execution (default: 3600 = 60 minutes)
# EXECUTE_TIMEOUT=3600

# ── Shell Configuration ───────────────────────────────────────────────────────
# Maximum output bytes before truncation (default: 10485760 = 10 MB)
# MAX_OUTPUT_BYTES=10485760

# Periodic cleanup interval in seconds (default: 3600 = 1 hour)
# CLEANUP_INTERVAL=3600

# ── Embedding Configuration ───────────────────────────────────────────────────
# Embedding model for vector search (default: text-embedding-3-small)
# EMBEDDING_MODEL=text-embedding-3-small

# ── Privacy & Features ───────────────────────────────────────────────────────
# Set to 1 to disable embeddings API (skip vector search)
# DISABLE_EMBEDDINGS=0

# Set to 1/true to enable autonomous state verification (idempotency check)
# ENABLE_IDEMPOTENCY_CHECK=false

# Set to 1/true to enable FileEditorTool (safe file read/write/append/str_replace)
# Replaces error-prone sed/awk/cat<<EOF shell commands for file edits
# ENABLE_FILE_EDITOR=false

# ── Auto-approve Mode ────────────────────────────────────────────────────────
# Set to 1 to auto-approve all commands (no interactive prompts)
# AUTO_APPROVE=0

# ── Prompt Customization ───────────────────────────────────────────────────────
# Directory containing custom prompt files (default: ~/.config/planner-shell/prompts)
# Set this to use your own custom prompts for planner, executor, and distill agents.
# Place planner.md, executor.md, and distill.md in this directory.
# PROMPT_DIR=~/.config/planner-shell/prompts
